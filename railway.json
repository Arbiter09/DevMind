{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "worker.Dockerfile"
  },
  "deploy": {
    "startCommand": "python -m backend.jobqueue.worker_entrypoint",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
